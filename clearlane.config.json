{
  "packageName": "@roshansharma/clearlane-mcp",
  "outputDir": "./output",
  "inputDir": "./input",
  "evidenceDir": "./input/evidence",
  "cacheDir": ".clearlane/cache",
  "dataSources": {
    "mtaBusTime": {
      "enabled": true,
      "apiKeyEnv": "MTA_API_KEY"
    },
    "nycOpenData": {
      "enabled": true,
      "appTokenEnv": "NYC_OPEN_DATA_APP_TOKEN"
    },
    "openaiVision": {
      "enabled": true,
      "apiKeyEnv": "OPENAI_API_KEY",
      "model": "gpt-4.1-mini"
    }
  },
  "datasets": {
    "mtaSegmentSpeeds": "kufs-yh3x",
    "nyc311": "erm2-nwe9",
    "nycBusLanes": "ycrg-ses3"
  },
  "privacy": {
    "stripImageMetadata": true,
    "blurFacesAndPlatesBestEffort": true,
    "doNotIdentifyPeople": true
  },
  "audit": {
    "ledgerFile": "audit-log.ndjson",
    "manifestFile": "audit-manifest.json",
    "hashAlgorithm": "sha256"
  }
}
